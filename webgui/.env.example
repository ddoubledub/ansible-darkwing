# =============================================================================
# .env.example — Ansible Playbook Builder configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored. Never commit it.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — these must be set before the app will work
# -----------------------------------------------------------------------------

# Absolute path to your ansible repo on the Docker host.
# This directory is mounted into the container as /repo.
ANSIBLE_REPO_PATH=/opt/ansible-repo

# Domain name for TLS. Caddy reads this to provision a certificate.
# Use a real FQDN for Let's Encrypt, or an internal hostname for self-signed.
# See Caddyfile for tls options.
DOMAIN=ansible-builder.example.com

# Session secret — used to sign session cookies. Must be unique per deployment.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=CHANGE_ME_GENERATE_A_RANDOM_HEX_STRING

# -----------------------------------------------------------------------------
# PATHS — host paths mounted into the container
# -----------------------------------------------------------------------------

# SSH key directory for git operations and ansible target access.
SSH_KEY_PATH=/home/ansible/.ssh

# Git identity file (sets commit author name and email inside the container).
GITCONFIG_PATH=/home/ansible/.gitconfig

# Vault password file. Set to /dev/null if not using ansible-vault.
VAULT_PASS_FILE=/home/ansible/.vault_pass

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------

# Basic Auth — simple username/password prompt in the browser.
# Good for internal use or while setting up SAML.
BASIC_AUTH_ENABLED=true
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=CHANGE_ME

# SAML — set to true after configuring saml/settings.json.
# See docs/ADMIN-GUIDE.md for Entra ID setup instructions.
SAML_ENABLED=false

# Session timeout in seconds. Default: 8 hours.
SESSION_MAX_AGE=28800

# -----------------------------------------------------------------------------
# OPTIONAL TUNING
# -----------------------------------------------------------------------------

# Max simultaneous ansible-playbook executions. Additional requests get 429.
MAX_CONCURRENT_RUNS=3

# Ansible version to install in the Docker image.
# See: https://pypi.org/project/ansible-core/#history
ANSIBLE_VERSION=2.17.*
